// ── Identity & access ────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  role             Role
  createdAt        DateTime @default(now())
  // Personal Telegram push notifications (matches, introductions,
  // verification) — opt-in, separate from the internal ops alert chat.
  // Telegram won't let a bot message someone who hasn't messaged it first,
  // so linking works via a one-time code the user sends to the bot; the
  // webhook resolves that code back to this row and fills in the chat id.
  telegramChatId   String?
  telegramLinkCode String?  @unique

  // TOTP two-factor auth (currently offered to ADMIN only). totpSecret is
  // written the moment setup starts but totpEnabled stays false until the
  // admin proves they can generate a real code — an unconfirmed secret
  // never gates login. Backup codes are bcrypt-hashed, single-use, removed
  // from the array the moment one is redeemed.
  totpSecret      String?
  totpEnabled     Boolean  @default(false)
  totpBackupCodes String[] @default([])

  // Brute-force lockout — applies to every role, not just admin. Counts
  // consecutive bad passwords; a correct login resets it to zero. Once
  // lockedUntil is in the future, login() refuses even a correct password
  // until it passes, so a guessed password alone can never be enough.
  failedLoginAttempts Int               @default(0)
  lockedUntil         DateTime?
  emailVerifiedAt     DateTime?
  mustSetPassword     Boolean           @default(false)
  adminPermissions    AdminPermission[] @default([])

  sessions                Session[]
  company                 CompanyProfile?
  partner                 PartnerProfile?
  customer                CustomerProfile?
  twoFactorChallenges     TwoFactorChallenge[]
  notifications           Notification[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

// In-app notification feed — the bell icon in the workspace shell. Written
// alongside every existing Telegram push (see notify() in src/lib/notify.ts)
// so nobody misses something important just because they haven't opened
// Telegram. Deliberately simple: no categories, no digesting, just a flat
// per-user list with a read flag.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Short-lived "password verified, waiting on a TOTP code" state — a login
// attempt lands here between the password step and a real Session existing.
// Never becomes a Session by itself; verifyTwoFactor() is the only path
// that turns one into an actual login.
model TwoFactorChallenge {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  next      String? // where to redirect after a successful verify
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model CustomerOtpChallenge {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  email      String
  quoteId    String?
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, expiresAt])
  @@index([quoteId])
}

// ── Companies & requests ─────────────────────────────────────────────────────

model CompanyProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  website      String?
  jurisdiction String
  contactName  String
  contactRole  String?
  telegram     String?
  phone        String?
  createdAt    DateTime @default(now())

  // Monthly retainer billing — a recurring service fee independent of any
  // single LiquidityRequest (e.g. ongoing partner-access / account management).
  // retainerNextRenewal is advanced by the retainer-renewal watchdog each time
  // it fires; retainerActive is the on/off switch operators use, so a paused
  // retainer keeps its config without being deleted.
  retainerActive      Boolean   @default(false)
  retainerAmount      Decimal?  @db.Decimal(18, 2)
  retainerCurrency    Currency?
  retainerDayOfMonth  Int?
  retainerNextRenewal DateTime?

  // Referral program (see src/lib/referral.ts) — referralCode is this
  // company's own shareable code (generated once, at signup), referredByCode
  // is the code they arrived with, if any (captured from ?ref= via cookie,
  // see src/lib/referral-capture.ts). Both nullable: referredByCode is
  // usually null (most signups aren't referred), and referralCode is only
  // ever null for accounts created before this feature existed.
  referralCode   String? @unique
  referredByCode String?

  requests     LiquidityRequest[]
  revenues     RevenueRecord[]
  organization Organization?
}

model LiquidityRequest {
  id                  String         @id @default(cuid())
  reference           String         @unique // REQ-0001
  companyId           String
  company             CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  direction           Direction
  requestType         RequestType    @default(INR_PAYOUTS)
  dailyVolumeBand     String
  monthlyVolumeBand   String
  ticketSize          String?
  urgency             Urgency        @default(STANDARD)
  countriesInvolved   String?
  banks               String[]
  methods             String[]
  requiredSpeed       String
  jurisdiction        String
  kycReadiness        String
  kycNotes            String?
  partnerRequirements String?
  notes               String?
  status              RequestStatus  @default(SUBMITTED)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // AI pre-flight triage — generated automatically right after submission
  // (see runRequestTriage in src/lib/ai-triage.ts), not on a click. Null
  // until the background pass completes (or forever, if AI isn't
  // configured). aiFlagged is parsed from a machine-readable marker line in
  // the model's own output so the admin list can filter/sort on it without
  // re-reading prose every time.
  aiTriageNote   String?
  aiFlagged      Boolean?
  routingEnabled Boolean  @default(true)

  matches     Match[]
  notesList   Note[]
  documents   DocumentRecord[]
  revenues    RevenueRecord[]
  matchOffers MatchOffer[]

  @@index([status])
  @@index([companyId])
}

// ── Partners ─────────────────────────────────────────────────────────────────

model PartnerProfile {
  id                   String        @id @default(cuid())
  userId               String        @unique
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference            String        @unique // PTR-0001
  displayName          String
  legalName            String?
  contactName          String
  telegram             String?
  phone                String?
  experienceBand       String
  directions           Direction[]
  banks                String[]
  methods              String[]
  dailyCapacityBand    String
  monthlyCapacityBand  String?
  minTicket            String?
  maxTicket            String?
  settlementPreference String?
  workingHours         String
  reserveBand          String
  jurisdictions        String
  operatingCountry     String?
  complianceFlags      String[]
  complianceNotes      String?
  references           String?
  riskNotes            String?
  additionalComments   String?
  status               PartnerStatus @default(APPLIED)
  tier                 PartnerTier   @default(CANDIDATE)
  verifiedAt           DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // AI pre-flight triage — generated automatically right after the partner
  // applies (see runPartnerTriage in src/lib/ai-triage.ts), mirroring the
  // same auto-triage LiquidityRequest gets on submission. Null until the
  // background pass completes (or forever, if AI isn't configured).
  aiTriageNote String?
  aiFlagged    Boolean?

  // Referral program — see the matching fields on CompanyProfile above for
  // the full explanation. Same shape on both sides of the marketplace.
  referralCode   String? @unique
  referredByCode String?

  matches             Match[]
  notesList           Note[]
  documents           DocumentRecord[]
  networkConnections  CompanyPartnerConnection[]
  verificationCases   VerificationCase[]
  capacityPulses      CapacityPulse[]
  matchOffers         MatchOffer[]
  incidents           Incident[]
  deposits            PartnerDeposit[]
  liquidityCapacities LiquidityCapacity[]
  Assignment          Assignment[]

  @@index([status])
}

model Organization {
  id                 String                     @id @default(cuid())
  companyProfileId   String                     @unique
  companyProfile     CompanyProfile             @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  name               String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  partnerConnections CompanyPartnerConnection[]
  verificationCases  VerificationCase[]
  matchOffers        MatchOffer[]

  @@index([name])
}

model CompanyPartnerConnection {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partnerId      String
  partner        PartnerProfile          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  status         NetworkConnectionStatus @default(INVITED)
  approvedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([organizationId, partnerId])
  @@index([partnerId, status])
}

model VerificationCase {
  id             String                 @id @default(cuid())
  reference      String                 @unique
  organizationId String?
  organization   Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partnerId      String?
  partner        PartnerProfile?        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       CustomerProfile?       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status         VerificationCaseStatus @default(IN_PROGRESS)
  riskLevel      String?
  decisionNote   String?
  decidedById    String?
  decidedAt      DateTime?
  expiresAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  checks         VerificationCheck[]
  evidence       EvidenceArtifact[]

  @@index([status, createdAt])
  @@index([organizationId])
  @@index([partnerId])
  @@index([customerId])
}

model VerificationCheck {
  id                 String                  @id @default(cuid())
  verificationCaseId String
  verificationCase   VerificationCase        @relation(fields: [verificationCaseId], references: [id], onDelete: Cascade)
  type               String
  provider           String?
  providerReference  String?
  status             VerificationCheckStatus @default(PENDING)
  summary            String?
  result             Json?
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([verificationCaseId, type])
  @@index([status])
}

model EvidenceArtifact {
  id                 String             @id @default(cuid())
  verificationCaseId String
  verificationCase   VerificationCase   @relation(fields: [verificationCaseId], references: [id], onDelete: Cascade)
  kind               EvidenceKind
  title              String
  storageKey         String             @unique
  mimeType           String
  byteSize           Int
  checksumSha256     String?
  classification     DataClassification @default(RESTRICTED)
  status             EvidenceStatus     @default(PENDING)
  uploadedById       String
  reviewedById       String?
  reviewedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([verificationCaseId, status])
  @@index([expiresAt])
}

model CapacityPulse {
  id             String         @id @default(cuid())
  partnerId      String
  partner        PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  status         CapacityStatus
  direction      Direction
  availableBand  String
  minTicket      String?
  maxTicket      String?
  banks          String[]
  methods        String[]
  confirmedAt    DateTime       @default(now())
  availableUntil DateTime
  createdAt      DateTime       @default(now())

  @@index([partnerId, confirmedAt])
  @@index([status, availableUntil])
}

model MatchOffer {
  id             String           @id @default(cuid())
  reference      String           @unique
  requestId      String
  request        LiquidityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId      String
  partner        PartnerProfile   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         MatchOfferStatus @default(PENDING)
  fitScore       Int
  reasonCodes    String[]
  capacityBand   String?
  termsSummary   String?
  expiresAt      DateTime
  respondedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([requestId, partnerId])
  @@index([partnerId, status, expiresAt])
}

model Incident {
  id           String           @id @default(cuid())
  reference    String           @unique
  partnerId    String?
  partner      PartnerProfile?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  severity     IncidentSeverity
  status       IncidentStatus   @default(OPEN)
  category     String
  summary      String
  details      String?
  openedById   String
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, severity])
  @@index([partnerId])
}

// USDT operating-reserve deposits. The destination address is snapshotted
// from configuration when an intent is created; private keys never enter the
// application. A partner submits the on-chain TXID and an operator verifies it.
model PartnerDeposit {
  id                    String         @id @default(cuid())
  reference             String         @unique
  partnerId             String
  partner               PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  amount                Decimal        @db.Decimal(18, 6)
  actualAmount          Decimal?       @db.Decimal(18, 6)
  currency              Currency       @default(USDT)
  network               String         @default("TRC20")
  status                DepositStatus  @default(AWAITING_PAYMENT)
  provider              String         @default("DIRECT_TRC20")
  destinationAddress    String?
  providerInvoiceId     String?        @unique
  providerInvoiceUrl    String?
  providerPaymentId     String?
  providerStatus        String?
  transactionHash       String?        @unique
  refundTransactionHash String?        @unique
  reviewedById          String?
  reviewNote            String?
  submittedAt           DateTime?
  confirmedAt           DateTime?
  refundedAt            DateTime?
  expiresAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([partnerId, createdAt])
  @@index([status, createdAt])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  externalId  String
  payloadHash String
  processedAt DateTime @default(now())

  @@unique([provider, externalId])
  @@index([processedAt])
}

// ── Customer transaction domain ──────────────────────────────────────────────

model CustomerProfile {
  id                   String                   @id @default(cuid())
  userId               String                   @unique
  user                 User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneEncrypted       String?
  phoneLast4           String?
  phoneVerifiedAt      DateTime?
  complianceStatus     CustomerComplianceStatus @default(NOT_STARTED)
  complianceReviewedAt DateTime?
  inrp2pId             String?                  @unique
  publicReceiveEnabled Boolean                  @default(false)
  inrPerOrderLimit     Decimal?                 @db.Decimal(18, 2)
  usdtPerOrderLimit    Decimal?                 @db.Decimal(18, 6)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  paymentMethods    PaymentMethod[]
  receiveProfile    ReceiveProfile?
  receiveLinks      ReceiveLink[]
  quotes            Quote[]            @relation("CustomerQuotes")
  recipientQuotes   Quote[]            @relation("RecipientQuotes")
  orders            Order[]            @relation("CustomerOrders")
  recipientOrders   Order[]            @relation("RecipientOrders")
  verificationCases VerificationCase[]

  @@index([complianceStatus])
}

model PaymentMethod {
  id               String               @id @default(cuid())
  customerId       String
  customer         CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type             PaymentMethodType
  purpose          PaymentMethodPurpose @default(BOTH)
  status           PaymentMethodStatus  @default(UNVERIFIED)
  label            String
  maskedLabel      String
  isDefaultSend    Boolean              @default(false)
  isDefaultReceive Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  bankAccount           BankAccount?
  upiHandle             UPIHandle?
  wallet                Wallet?
  sourceOrders          Order[]                  @relation("OrderSourceMethod")
  destinationOrders     Order[]                  @relation("OrderDestinationMethod")
  sourceQuoteHints      Quote[]                  @relation("QuoteSourceMethodHint")
  destinationQuoteHints Quote[]                  @relation("QuoteDestinationMethodHint")
  primaryForProfile     ReceiveProfile?          @relation("PrimaryReceiveMethod")
  fallbackForProfiles   ReceiveProfileFallback[]

  @@index([customerId, type, status])
}

model BankAccount {
  id                     String        @id @default(cuid())
  paymentMethodId        String        @unique
  paymentMethod          PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  accountHolderEncrypted String
  accountNumberEncrypted String
  accountNumberHash      String        @unique
  accountLast4           String
  ifscEncrypted          String
  ifscMasked             String
  bankName               String
  ownershipVerifiedAt    DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model UPIHandle {
  id                  String        @id @default(cuid())
  paymentMethodId     String        @unique
  paymentMethod       PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  handleEncrypted     String
  handleHash          String        @unique
  handleMasked        String
  ownershipVerifiedAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Wallet {
  id                  String        @id @default(cuid())
  paymentMethodId     String        @unique
  paymentMethod       PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  network             WalletNetwork
  addressEncrypted    String
  addressHash         String        @unique
  addressLast4        String
  formatValidatedAt   DateTime?
  ownershipVerifiedAt DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model ReceiveProfile {
  id              String                   @id @default(cuid())
  customerId      String                   @unique
  customer        CustomerProfile          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  primaryMethodId String?                  @unique
  primaryMethod   PaymentMethod?           @relation("PrimaryReceiveMethod", fields: [primaryMethodId], references: [id], onDelete: SetNull)
  available       Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  fallbacks       ReceiveProfileFallback[]
}

model ReceiveProfileFallback {
  id               String         @id @default(cuid())
  receiveProfileId String
  receiveProfile   ReceiveProfile @relation(fields: [receiveProfileId], references: [id], onDelete: Cascade)
  paymentMethodId  String
  paymentMethod    PaymentMethod  @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  position         Int

  @@unique([receiveProfileId, paymentMethodId])
  @@unique([receiveProfileId, position])
}

model ReceiveLink {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String          @unique
  amount     Decimal?        @db.Decimal(18, 6)
  currency   Currency?
  memo       String?
  expiresAt  DateTime?
  maxUses    Int?
  useCount   Int             @default(0)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  quotes     Quote[]

  @@index([customerId, active])
  @@index([expiresAt])
}

model Quote {
  id                      String           @id @default(cuid())
  customerId              String?
  customer                CustomerProfile? @relation("CustomerQuotes", fields: [customerId], references: [id], onDelete: SetNull)
  recipientCustomerId     String?
  recipientCustomer       CustomerProfile? @relation("RecipientQuotes", fields: [recipientCustomerId], references: [id], onDelete: SetNull)
  receiveLinkId           String?
  receiveLink             ReceiveLink?     @relation(fields: [receiveLinkId], references: [id], onDelete: SetNull)
  clientTokenHash         String           @unique
  direction               Direction
  exactSide               QuoteExactSide
  inputAmount             Decimal          @db.Decimal(18, 6)
  sendCurrency            Currency
  receiveCurrency         Currency
  sendAmount              Decimal          @db.Decimal(18, 6)
  receiveAmount           Decimal          @db.Decimal(18, 6)
  rate                    Decimal          @db.Decimal(18, 8)
  feeAmount               Decimal          @db.Decimal(18, 6)
  feeCurrency             Currency
  feeBps                  Int
  provider                String
  providerReference       String?
  sourceMethodHintId      String?
  sourceMethodHint        PaymentMethod?   @relation("QuoteSourceMethodHint", fields: [sourceMethodHintId], references: [id], onDelete: SetNull)
  destinationMethodHintId String?
  destinationMethodHint   PaymentMethod?   @relation("QuoteDestinationMethodHint", fields: [destinationMethodHintId], references: [id], onDelete: SetNull)
  status                  QuoteStatus      @default(ACTIVE)
  expiresAt               DateTime
  createdAt               DateTime         @default(now())
  order                   Order?

  @@index([customerId, createdAt])
  @@index([recipientCustomerId, createdAt])
  @@index([receiveLinkId])
  @@index([status, expiresAt])
}

model Order {
  id                         String           @id @default(cuid())
  reference                  String           @unique
  customerId                 String
  customer                   CustomerProfile  @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  recipientCustomerId        String?
  recipientCustomer          CustomerProfile? @relation("RecipientOrders", fields: [recipientCustomerId], references: [id], onDelete: SetNull)
  quoteId                    String           @unique
  quote                      Quote            @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  sourcePaymentMethodId      String
  sourcePaymentMethod        PaymentMethod    @relation("OrderSourceMethod", fields: [sourcePaymentMethodId], references: [id], onDelete: Restrict)
  destinationPaymentMethodId String
  destinationPaymentMethod   PaymentMethod    @relation("OrderDestinationMethod", fields: [destinationPaymentMethodId], references: [id], onDelete: Restrict)
  direction                  Direction
  status                     OrderStatus      @default(AWAITING_PAYMENT)
  sendCurrency               Currency
  receiveCurrency            Currency
  sendAmount                 Decimal          @db.Decimal(18, 6)
  receiveAmount              Decimal          @db.Decimal(18, 6)
  rate                       Decimal          @db.Decimal(18, 8)
  feeAmount                  Decimal          @db.Decimal(18, 6)
  feeCurrency                Currency
  idempotencyKey             String           @unique
  version                    Int              @default(1)
  attentionReason            String?
  paymentDeadline            DateTime?
  paymentSubmittedAt         DateTime?
  paymentConfirmedAt         DateTime?
  paymentConfirmedById       String?
  settlementReleasedById     String?
  settlementSentAt           DateTime?
  completedAt                DateTime?
  cancelledAt                DateTime?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  legs               OrderLeg[]
  paymentAttempts    PaymentAttempt[]
  settlementAttempts SettlementAttempt[]
  evidence           TransactionEvidence[]
  disputes           Dispute[]
  reconciliation     Reconciliation?

  @@index([customerId, createdAt])
  @@index([status, updatedAt])
}

model OrderLeg {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sequence      Int
  status        OrderLegStatus @default(PENDING)
  sendAmount    Decimal        @db.Decimal(18, 6)
  receiveAmount Decimal        @db.Decimal(18, 6)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  assignments        Assignment[]
  paymentAttempts    PaymentAttempt[]
  settlementAttempts SettlementAttempt[]
  evidence           TransactionEvidence[]

  @@unique([orderId, sequence])
  @@index([orderId, status])
}

model LiquidityCapacity {
  id                         String                  @id @default(cuid())
  partnerId                  String
  partner                    PartnerProfile          @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  direction                  Direction
  status                     LiquidityCapacityStatus @default(AVAILABLE)
  declaredInr                Decimal                 @db.Decimal(18, 2)
  reservedInr                Decimal                 @default(0) @db.Decimal(18, 2)
  availableInr               Decimal                 @db.Decimal(18, 2)
  pendingInr                 Decimal                 @default(0) @db.Decimal(18, 2)
  settledInr                 Decimal                 @default(0) @db.Decimal(18, 2)
  declaredUsdt               Decimal                 @db.Decimal(18, 6)
  reservedUsdt               Decimal                 @default(0) @db.Decimal(18, 6)
  availableUsdt              Decimal                 @db.Decimal(18, 6)
  pendingUsdt                Decimal                 @default(0) @db.Decimal(18, 6)
  settledUsdt                Decimal                 @default(0) @db.Decimal(18, 6)
  minInr                     Decimal?                @db.Decimal(18, 2)
  maxInr                     Decimal?                @db.Decimal(18, 2)
  minUsdt                    Decimal?                @db.Decimal(18, 6)
  maxUsdt                    Decimal?                @db.Decimal(18, 6)
  rails                      PaymentRail[]
  networks                   WalletNetwork[]
  banks                      String[]
  collectionDetailsEncrypted String
  collectionDetailsMasked    String
  workingHours               Json?
  lastConfirmedAt            DateTime
  availableUntil             DateTime
  version                    Int                     @default(1)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  assignments Assignment[]

  @@index([direction, status, availableUntil])
  @@index([partnerId, updatedAt])
}

model Assignment {
  id                     String                @id @default(cuid())
  orderLegId             String
  orderLeg               OrderLeg              @relation(fields: [orderLegId], references: [id], onDelete: Restrict)
  partnerId              String
  partner                PartnerProfile        @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  liquidityCapacityId    String
  liquidityCapacity      LiquidityCapacity     @relation(fields: [liquidityCapacityId], references: [id], onDelete: Restrict)
  previousAssignmentId   String?
  previousAssignment     Assignment?           @relation("AssignmentHistory", fields: [previousAssignmentId], references: [id], onDelete: SetNull)
  replacementAssignments Assignment[]          @relation("AssignmentHistory")
  status                 AssignmentStatus      @default(ACTIVE)
  reservedInr            Decimal               @db.Decimal(18, 2)
  reservedUsdt           Decimal               @db.Decimal(18, 6)
  idempotencyKey         String                @unique
  frozenAt               DateTime?
  frozenReason           String?
  releasedAt             DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  evidence               TransactionEvidence[]

  @@index([orderLegId, status])
  @@index([partnerId, status])
}

model PaymentAttempt {
  id                    String                @id @default(cuid())
  orderId               String
  order                 Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLegId            String?
  orderLeg              OrderLeg?             @relation(fields: [orderLegId], references: [id], onDelete: SetNull)
  status                PaymentAttemptStatus  @default(CREATED)
  rail                  PaymentRail
  amount                Decimal               @db.Decimal(18, 6)
  currency              Currency
  instructionsEncrypted String
  instructionsMasked    String
  provider              String?
  providerReference     String?
  utrEncrypted          String?
  utrHash               String?               @unique
  utrMasked             String?
  txid                  String?               @unique
  expiresAt             DateTime?
  submittedAt           DateTime?
  detectedAt            DateTime?
  confirmedAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  evidence              TransactionEvidence[]

  @@unique([provider, providerReference])
  @@index([orderId, status])
}

model SettlementAttempt {
  id                       String                  @id @default(cuid())
  orderId                  String
  order                    Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLegId               String?
  orderLeg                 OrderLeg?               @relation(fields: [orderLegId], references: [id], onDelete: SetNull)
  status                   SettlementAttemptStatus @default(CREATED)
  amount                   Decimal                 @db.Decimal(18, 6)
  currency                 Currency
  network                  WalletNetwork?
  provider                 String?
  providerReference        String?
  idempotencyKey           String                  @unique
  destinationMasked        String
  payoutReferenceEncrypted String?
  payoutReferenceHash      String?                 @unique
  payoutReferenceMasked    String?
  txid                     String?                 @unique
  failureReason            String?
  startedAt                DateTime?
  sentAt                   DateTime?
  detectedAt               DateTime?
  confirmedAt              DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  evidence                 TransactionEvidence[]

  @@unique([provider, providerReference])
  @@index([orderId, status])
}

model TransactionEvidence {
  id                  String                  @id @default(cuid())
  orderId             String
  order               Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLegId          String?
  orderLeg            OrderLeg?               @relation(fields: [orderLegId], references: [id], onDelete: SetNull)
  assignmentId        String?
  assignment          Assignment?             @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  paymentAttemptId    String?
  paymentAttempt      PaymentAttempt?         @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)
  settlementAttemptId String?
  settlementAttempt   SettlementAttempt?      @relation(fields: [settlementAttemptId], references: [id], onDelete: SetNull)
  kind                TransactionEvidenceKind
  title               String
  storageKey          String                  @unique
  mimeType            String
  byteSize            Int
  checksumSha256      String
  classification      DataClassification      @default(RESTRICTED)
  uploadedById        String?
  createdAt           DateTime                @default(now())

  @@index([orderId, createdAt])
  @@index([assignmentId])
}

model Dispute {
  id           String        @id @default(cuid())
  reference    String        @unique
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status       DisputeStatus @default(OPEN)
  reason       String
  details      String?
  openedById   String
  resolvedById String?
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId, status])
}

model Reconciliation {
  id                    String               @id @default(cuid())
  orderId               String               @unique
  order                 Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status                ReconciliationStatus @default(PENDING)
  paymentMatched        Boolean              @default(false)
  settlementMatched     Boolean              @default(false)
  expectedSendAmount    Decimal              @db.Decimal(18, 6)
  observedSendAmount    Decimal?             @db.Decimal(18, 6)
  expectedReceiveAmount Decimal              @db.Decimal(18, 6)
  observedReceiveAmount Decimal?             @db.Decimal(18, 6)
  exceptionReason       String?
  reconciledById        String?
  reconciledAt          DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model RateLimitState {
  id          String   @id
  count       Int      @default(0)
  windowStart DateTime
  expiresAt   DateTime

  @@index([expiresAt])
}

// ── Matching & introductions ─────────────────────────────────────────────────

model Match {
  id                String           @id @default(cuid())
  requestId         String
  request           LiquidityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           PartnerProfile   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  status            MatchStatus      @default(SUGGESTED)
  adminNote         String?
  confidenceScore   Int?
  nextAction        String?
  // AI-generated plain-language justification for this pairing — separate
  // from adminNote (human-entered) and the ranking engine's `reasons` (not
  // persisted, computed on the fly). Shown to both operations and the
  // company. Null until an operator generates it once.
  aiExplanation     String?
  releasedToCompany Boolean          @default(false)
  releasedToPartner Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  introductions Introduction[]
  revenues      RevenueRecord[]
  notesList     Note[]

  @@unique([requestId, partnerId])
  @@index([status])
}

model Introduction {
  id           String             @id @default(cuid())
  matchId      String
  match        Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  status       IntroductionStatus @default(PENDING)
  channel      IntroChannel       @default(EMAIL)
  summary      String?
  outcome      String?
  followUpDate DateTime?
  sentAt       DateTime?
  respondedAt  DateTime?
  // Optional, admin-entered effective settlement rate (INR per 1 USDT) for
  // closed INR_TO_USDT / USDT_TO_INR deals — feeds the public reference-rate
  // index. Never required, never touches INR_PAYOUTS (no conversion rate
  // concept there), and is aggregated, not published per-deal.
  settledRate  Decimal?           @db.Decimal(10, 4)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  messages IntroductionMessage[]

  @@index([matchId])
}

// In-platform "deal room" thread for a single introduction — keeps the
// post-intro conversation (and the trust/visibility it represents) on the
// platform instead of leaking entirely to outside email/Telegram the moment
// two sides are connected. Deliberately simple: no attachments, no threads,
// just a flat timestamped log both sides and ops can see.
model IntroductionMessage {
  id             String         @id @default(cuid())
  introductionId String
  introduction   Introduction   @relation(fields: [introductionId], references: [id], onDelete: Cascade)
  authorId       String? // User.id — null only if the author account was later deleted
  authorLabel    String // denormalized: company name / partner display name / "Operator"
  authorSide     NoteVisibility // reuse COMPANY / PARTNER / INTERNAL(=operator) as the sender's side
  body           String
  createdAt      DateTime       @default(now())

  @@index([introductionId])
}

// ── Revenue ──────────────────────────────────────────────────────────────────

model RevenueRecord {
  id               String            @id @default(cuid())
  // Optional as of the retainer-billing feature: a MONTHLY_RETAINER record is
  // tied to a company directly (companyId below), not to any one request.
  // Every pre-existing/request-driven revenue record still sets requestId.
  requestId        String?
  request          LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  companyId        String?
  company          CompanyProfile?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchId          String?
  match            Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)
  amount           Decimal           @db.Decimal(18, 2)
  currency         Currency          @default(INR)
  type             RevenueType       @default(CUSTOM)
  payerType        String? // e.g. "Company", "Partner"
  payerName        String?
  basis            String? // e.g. "25 bps on first month volume", "fixed introduction fee"
  status           RevenueStatus     @default(POTENTIAL)
  dueDate          DateTime?
  invoicedAt       DateTime?
  paidAt           DateTime?
  // Razorpay Payment Links — collection of INRP2P's own service fee only,
  // never the underlying P2P trade funds between company and partner.
  // @unique so the webhook can look up the exact record with findUnique
  // instead of findFirst — guarantees it can never update the wrong row
  // even if duplicate ids were ever written by a bug or manual edit.
  paymentLinkId    String?           @unique // Razorpay's plink_xxx id
  paymentLinkUrl   String? // short_url — shareable link sent to the payer
  paymentRef       String? // Razorpay's pay_xxx id once the link is paid
  // NOWPayments — non-custodial USDT collection for INRP2P's own fee when
  // the payer settles in crypto instead of INR. Same boundary as Razorpay:
  // only ever INRP2P's own commission, never the underlying P2P trade
  // funds. Looked up in the webhook via order_id = this record's own id,
  // so no separate unique constraint is needed here (unlike paymentLinkId).
  cryptoInvoiceId  String? // NOWPayments invoice id
  cryptoInvoiceUrl String? // invoice_url — shareable hosted payment link
  cryptoPaymentRef String? // NOWPayments payment_id once paid
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([status])
}

// ── Notes & documents ────────────────────────────────────────────────────────

model Note {
  id          String            @id @default(cuid())
  body        String
  visibility  NoteVisibility    @default(INTERNAL)
  authorLabel String // denormalized: "Operator", company name, partner name
  authorId    String?
  requestId   String?
  request     LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId   String?
  partner     PartnerProfile?   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  matchId     String?
  match       Match?            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@index([requestId])
  @@index([partnerId])
}

model DocumentRecord {
  id          String            @id @default(cuid())
  title       String
  url         String?
  note        String?
  visibility  NoteVisibility    @default(INTERNAL)
  authorLabel String
  authorId    String?
  requestId   String?
  request     LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId   String?
  partner     PartnerProfile?   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@index([requestId])
  @@index([partnerId])
}

// ── Audit trail ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. request.status_changed
  entityType String
  entityId   String
  actorId    String?
  actorLabel String
  requestId  String?
  partnerId  String?
  matchId    String?
  orderId    String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([partnerId])
  @@index([orderId])
  @@index([createdAt])
}

// ── Error monitoring ─────────────────────────────────────────────────────────
// Native substitute for Sentry — there's no network access for `npm install`
// in this build environment, so unhandled errors are captured by hand: caught
// in error.tsx/global-error.tsx and key server-action/route catch blocks,
// written here, and (for ERROR/FATAL) pushed to the existing ops Telegram
// chat. Resolved errors are kept, not deleted, for a real audit trail.

enum ErrorSeverity {
  WARNING
  ERROR
  FATAL
}

model ErrorLog {
  id         String        @id @default(cuid())
  severity   ErrorSeverity @default(ERROR)
  message    String
  stack      String? // truncated stack trace, if available
  source     String // e.g. "server-action:updateRequestStatus", "route:/api/webhooks/razorpay", "client:error-boundary"
  url        String? // request path, when known
  userId     String? // actor at the time, when known — no FK, so a deleted user never blocks logging
  meta       Json?
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([resolved, createdAt])
  @@index([severity])
}

// ── Utility ──────────────────────────────────────────────────────────────────

model Counter {
  key   String @id
  value Int    @default(0)
}
