// INRP2P — private INR liquidity network.
// Coordination layer only: review, matching, qualified introductions.
// No custody, no funds movement, no execution.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations / db push.
  // On Vercel+Neon this is added automatically as DATABASE_URL_UNPOOLED.
  // Locally, set it to the same value as DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  COMPANY
  PARTNER
}

enum Direction {
  INR_TO_USDT
  USDT_TO_INR
  INR_PAYOUTS
}

// Broader intake categorisation than Direction — includes non-corridor request
// types (partner sourcing, other) that Direction deliberately does not cover,
// since Direction also drives partner-matching eligibility and must stay a
// clean 3-value corridor enum.
enum RequestType {
  INR_PAYOUTS
  INR_LIQUIDITY
  INR_TO_USDT
  USDT_TO_INR
  PARTNER_SOURCING
  OTHER
}

enum Urgency {
  STANDARD
  URGENT
  CRITICAL
}

enum RevenueType {
  REVIEW_FEE
  PARTNER_ACCESS
  INTRO_FEE
  SUCCESS_FEE
  MONTHLY_RETAINER
  CUSTOM
}

enum RequestStatus {
  SUBMITTED
  IN_REVIEW
  MATCHING
  INTRODUCED
  CLOSED
  REJECTED
}

enum PartnerStatus {
  APPLIED
  UNDER_REVIEW
  VERIFIED
  LIMITED
  REJECTED
  SUSPENDED
}

enum MatchStatus {
  SUGGESTED
  SHORTLISTED
  INTRODUCED
  ACCEPTED
  DECLINED
}

enum IntroductionStatus {
  PENDING
  SENT
  RESPONDED
  SUCCESSFUL
  FAILED
}

enum RevenueStatus {
  POTENTIAL
  QUOTED
  AGREED
  INVOICED
  PAID
  CANCELLED
  LOST
  WAIVED
}

enum NoteVisibility {
  INTERNAL // admin only
  COMPANY  // admin + owning company
  PARTNER  // admin + owning partner
}

enum IntroChannel {
  EMAIL
  TELEGRAM
  CALL
  OTHER
}

enum Currency {
  INR
  USDT
  USD
}

// ── Identity & access ────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())
  // Personal Telegram push notifications (matches, introductions,
  // verification) — opt-in, separate from the internal ops alert chat.
  // Telegram won't let a bot message someone who hasn't messaged it first,
  // so linking works via a one-time code the user sends to the bot; the
  // webhook resolves that code back to this row and fills in the chat id.
  telegramChatId   String?
  telegramLinkCode String? @unique

  // TOTP two-factor auth (currently offered to ADMIN only). totpSecret is
  // written the moment setup starts but totpEnabled stays false until the
  // admin proves they can generate a real code — an unconfirmed secret
  // never gates login. Backup codes are bcrypt-hashed, single-use, removed
  // from the array the moment one is redeemed.
  totpSecret       String?
  totpEnabled      Boolean  @default(false)
  totpBackupCodes  String[] @default([])

  // Brute-force lockout — applies to every role, not just admin. Counts
  // consecutive bad passwords; a correct login resets it to zero. Once
  // lockedUntil is in the future, login() refuses even a correct password
  // until it passes, so a guessed password alone can never be enough.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  sessions Session[]
  company  CompanyProfile?
  partner  PartnerProfile?
  twoFactorChallenges TwoFactorChallenge[]
  notifications Notification[]
}

// In-app notification feed — the bell icon in the workspace shell. Written
// alongside every existing Telegram push (see notify() in src/lib/notify.ts)
// so nobody misses something important just because they haven't opened
// Telegram. Deliberately simple: no categories, no digesting, just a flat
// per-user list with a read flag.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Short-lived "password verified, waiting on a TOTP code" state — a login
// attempt lands here between the password step and a real Session existing.
// Never becomes a Session by itself; verifyTwoFactor() is the only path
// that turns one into an actual login.
model TwoFactorChallenge {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  next      String? // where to redirect after a successful verify
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Companies & requests ─────────────────────────────────────────────────────

model CompanyProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  website      String?
  jurisdiction String
  contactName  String
  contactRole  String?
  telegram     String?
  phone        String?
  createdAt    DateTime @default(now())

  // Monthly retainer billing — a recurring service fee independent of any
  // single LiquidityRequest (e.g. ongoing partner-access / account management).
  // retainerNextRenewal is advanced by the retainer-renewal watchdog each time
  // it fires; retainerActive is the on/off switch operators use, so a paused
  // retainer keeps its config without being deleted.
  retainerActive       Boolean   @default(false)
  retainerAmount       Decimal?  @db.Decimal(18, 2)
  retainerCurrency     Currency?
  retainerDayOfMonth   Int?
  retainerNextRenewal  DateTime?

  requests LiquidityRequest[]
  revenues RevenueRecord[]
}

model LiquidityRequest {
  id               String        @id @default(cuid())
  reference        String        @unique // REQ-0001
  companyId        String
  company          CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  direction        Direction
  requestType      RequestType   @default(INR_PAYOUTS)
  dailyVolumeBand  String
  monthlyVolumeBand String
  ticketSize        String?
  urgency           Urgency      @default(STANDARD)
  countriesInvolved String?
  banks            String[]
  methods          String[]
  requiredSpeed    String
  jurisdiction     String
  kycReadiness     String
  kycNotes         String?
  partnerRequirements String?
  notes            String?
  status           RequestStatus @default(SUBMITTED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  matches   Match[]
  notesList Note[]
  documents DocumentRecord[]
  revenues  RevenueRecord[]

  @@index([status])
  @@index([companyId])
}

// ── Partners ─────────────────────────────────────────────────────────────────

model PartnerProfile {
  id                String        @id @default(cuid())
  userId            String        @unique
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference         String        @unique // PTR-0001
  displayName       String
  legalName         String?
  contactName       String
  telegram          String?
  phone             String?
  experienceBand    String
  directions        Direction[]
  banks             String[]
  methods           String[]
  dailyCapacityBand String
  monthlyCapacityBand String?
  minTicket           String?
  maxTicket           String?
  settlementPreference String?
  workingHours      String
  reserveBand       String
  jurisdictions     String
  operatingCountry    String?
  complianceFlags   String[]
  complianceNotes   String?
  references          String?
  riskNotes           String?
  additionalComments  String?
  status            PartnerStatus @default(APPLIED)
  verifiedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  matches   Match[]
  notesList Note[]
  documents DocumentRecord[]

  @@index([status])
}

// ── Matching & introductions ─────────────────────────────────────────────────

model Match {
  id                String      @id @default(cuid())
  requestId         String
  request           LiquidityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           PartnerProfile   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  status            MatchStatus @default(SUGGESTED)
  adminNote         String?
  confidenceScore   Int?
  nextAction        String?
  // AI-generated plain-language justification for this pairing — separate
  // from adminNote (human-entered) and the ranking engine's `reasons` (not
  // persisted, computed on the fly). Shown to both operations and the
  // company. Null until an operator generates it once.
  aiExplanation     String?
  releasedToCompany Boolean     @default(false)
  releasedToPartner Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  introductions Introduction[]
  revenues      RevenueRecord[]
  notesList     Note[]

  @@unique([requestId, partnerId])
  @@index([status])
}

model Introduction {
  id          String             @id @default(cuid())
  matchId     String
  match       Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)
  status      IntroductionStatus @default(PENDING)
  channel     IntroChannel       @default(EMAIL)
  summary     String?
  outcome     String?
  followUpDate DateTime?
  sentAt      DateTime?
  respondedAt DateTime?
  // Optional, admin-entered effective settlement rate (INR per 1 USDT) for
  // closed INR_TO_USDT / USDT_TO_INR deals — feeds the public reference-rate
  // index. Never required, never touches INR_PAYOUTS (no conversion rate
  // concept there), and is aggregated, not published per-deal.
  settledRate Decimal?           @db.Decimal(10, 4)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  messages IntroductionMessage[]

  @@index([matchId])
}

// In-platform "deal room" thread for a single introduction — keeps the
// post-intro conversation (and the trust/visibility it represents) on the
// platform instead of leaking entirely to outside email/Telegram the moment
// two sides are connected. Deliberately simple: no attachments, no threads,
// just a flat timestamped log both sides and ops can see.
model IntroductionMessage {
  id             String       @id @default(cuid())
  introductionId String
  introduction   Introduction @relation(fields: [introductionId], references: [id], onDelete: Cascade)
  authorId       String? // User.id — null only if the author account was later deleted
  authorLabel    String // denormalized: company name / partner display name / "Operator"
  authorSide     NoteVisibility // reuse COMPANY / PARTNER / INTERNAL(=operator) as the sender's side
  body           String
  createdAt      DateTime     @default(now())

  @@index([introductionId])
}

// ── Revenue ──────────────────────────────────────────────────────────────────

model RevenueRecord {
  id         String        @id @default(cuid())
  // Optional as of the retainer-billing feature: a MONTHLY_RETAINER record is
  // tied to a company directly (companyId below), not to any one request.
  // Every pre-existing/request-driven revenue record still sets requestId.
  requestId  String?
  request    LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  companyId  String?
  company    CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matchId    String?
  match      Match?        @relation(fields: [matchId], references: [id], onDelete: SetNull)
  amount     Decimal       @db.Decimal(18, 2)
  currency   Currency      @default(INR)
  type       RevenueType   @default(CUSTOM)
  payerType  String? // e.g. "Company", "Partner"
  payerName  String?
  basis      String? // e.g. "25 bps on first month volume", "fixed introduction fee"
  status     RevenueStatus @default(POTENTIAL)
  dueDate    DateTime?
  invoicedAt DateTime?
  paidAt     DateTime?
  // Razorpay Payment Links — collection of INRP2P's own service fee only,
  // never the underlying P2P trade funds between company and partner.
  // @unique so the webhook can look up the exact record with findUnique
  // instead of findFirst — guarantees it can never update the wrong row
  // even if duplicate ids were ever written by a bug or manual edit.
  paymentLinkId  String? @unique // Razorpay's plink_xxx id
  paymentLinkUrl String? // short_url — shareable link sent to the payer
  paymentRef     String? // Razorpay's pay_xxx id once the link is paid
  // NOWPayments — non-custodial USDT collection for INRP2P's own fee when
  // the payer settles in crypto instead of INR. Same boundary as Razorpay:
  // only ever INRP2P's own commission, never the underlying P2P trade
  // funds. Looked up in the webhook via order_id = this record's own id,
  // so no separate unique constraint is needed here (unlike paymentLinkId).
  cryptoInvoiceId  String? // NOWPayments invoice id
  cryptoInvoiceUrl String? // invoice_url — shareable hosted payment link
  cryptoPaymentRef String? // NOWPayments payment_id once paid
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
}

// ── Notes & documents ────────────────────────────────────────────────────────

model Note {
  id          String         @id @default(cuid())
  body        String
  visibility  NoteVisibility @default(INTERNAL)
  authorLabel String // denormalized: "Operator", company name, partner name
  authorId    String?
  requestId   String?
  request     LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId   String?
  partner     PartnerProfile?   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  matchId     String?
  match       Match?            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@index([requestId])
  @@index([partnerId])
}

model DocumentRecord {
  id          String         @id @default(cuid())
  title       String
  url         String?
  note        String?
  visibility  NoteVisibility @default(INTERNAL)
  authorLabel String
  authorId    String?
  requestId   String?
  request     LiquidityRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partnerId   String?
  partner     PartnerProfile?   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@index([requestId])
  @@index([partnerId])
}

// ── Audit trail ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. request.status_changed
  entityType String
  entityId   String
  actorId    String?
  actorLabel String
  requestId  String?
  partnerId  String?
  matchId    String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([partnerId])
  @@index([createdAt])
}

// ── Error monitoring ─────────────────────────────────────────────────────────
// Native substitute for Sentry — there's no network access for `npm install`
// in this build environment, so unhandled errors are captured by hand: caught
// in error.tsx/global-error.tsx and key server-action/route catch blocks,
// written here, and (for ERROR/FATAL) pushed to the existing ops Telegram
// chat. Resolved errors are kept, not deleted, for a real audit trail.

enum ErrorSeverity {
  WARNING
  ERROR
  FATAL
}

model ErrorLog {
  id         String        @id @default(cuid())
  severity   ErrorSeverity @default(ERROR)
  message    String
  stack      String? // truncated stack trace, if available
  source     String // e.g. "server-action:updateRequestStatus", "route:/api/webhooks/razorpay", "client:error-boundary"
  url        String? // request path, when known
  userId     String? // actor at the time, when known — no FK, so a deleted user never blocks logging
  meta       Json?
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([resolved, createdAt])
  @@index([severity])
}

// ── Utility ──────────────────────────────────────────────────────────────────

model Counter {
  key   String @id
  value Int    @default(0)
}
