// INRP2P — controlled INR ↔ USDT transaction and liquidity operations.
// Customer complexity stays behind a server-enforced transaction lifecycle.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations / db push.
  // On Vercel+Neon this is added automatically as DATABASE_URL_UNPOOLED.
  // Locally, set it to the same value as DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

