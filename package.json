{
  "name": "inrp2p",
  "version": "1.0.0",
  "private": true,
  "description": "INRP2P — private INR liquidity network. Manual review, matching and qualified introductions. No custody, no execution.",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check": "npm run db:validate && npm run lint && npm run typecheck && npm test && npm run build",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:demo": "tsx prisma/seed-demo.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.7.0",
    "bcryptjs": "2.4.3",
    "next": "^15.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^20.17.30",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "postcss": "^8.5.3",
    "prisma": "6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
