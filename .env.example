# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, RDS, or self-hosted).
DATABASE_URL="postgresql://inrp2p:inrp2p@localhost:5432/inrp2p?schema=public"
# Direct (non-pooled) connection used by prisma migrate / db push.
# On Vercel+Neon this is set automatically; locally use the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://inrp2p:inrp2p@localhost:5432/inrp2p?schema=public"

# ── Initial admin account (created by `npm run db:seed`) ────────────────────
# CHANGE BOTH VALUES BEFORE DEPLOYING. The seed only creates this one user —
# no fake companies, partners, requests, or deals are ever seeded.
ADMIN_EMAIL="admin@inrp2p.local"
ADMIN_PASSWORD="inrp2p-admin-2026"
ADMIN_NAME="Network Operator"

# ── Public site ─────────────────────────────────────────────────────────────
# Canonical production URL — used for SEO (sitemap, canonical, Open Graph).
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
# Shown on the public contact section and confirmation pages.
NEXT_PUBLIC_CONTACT_EMAIL="network@inrp2p.example"
NEXT_PUBLIC_CONTACT_TELEGRAM="inrp2p_network"

# ── Ops (optional) ───────────────────────────────────────────────────────────
# Human-readable release tag shown in the operator sidebar footer.
# Falls back to the platform commit SHA, then "dev", if unset.
NEXT_PUBLIC_APP_VERSION=""

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Google Analytics 4 measurement ID. Set this in Vercel's Production
# environment only — leave it unset locally and in Preview deploys so test
# traffic doesn't pollute production analytics. When unset, no gtag script
# is rendered at all.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ── Ops watchdogs (optional) ─────────────────────────────────────────────────
# Telegram bot token from @BotFather. Without this, watchdog alerts are
# skipped silently (logged server-side, nothing sent) — the app still works.
TELEGRAM_BOT_TOKEN=""
# Numeric chat ID the bot pushes alerts to. Telegram won't let a bot message
# someone who hasn't messaged it first — open a chat with your bot, send it
# anything, then look up the resulting chat_id (e.g. via getUpdates), or add
# the bot to a private ops group/channel and use that chat's ID instead.
TELEGRAM_ALERT_CHAT_ID=""
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# calling /api/cron/watchdogs. Set the same value here and in Vercel's
# Environment Variables. If unset, the cron route runs unauthenticated —
# fine for local testing, not for production.
CRON_SECRET=""

# ── Personal Telegram notifications for companies/partners (optional) ───────
# Reuses the SAME bot as the ops watchdogs above (TELEGRAM_BOT_TOKEN) — this
# just adds an incoming-message webhook so a company or partner can link
# their own chat and get pushed a message the moment they get an
# introduction or a partner gets verified. Without TELEGRAM_WEBHOOK_SECRET
# set, the "Connect Telegram" card still shows but the webhook rejects
# every request — set it before relying on this.
#
# A value YOU choose (not something Telegram gives you) — set the same
# value here and pass it to Telegram when registering the webhook (one-time,
# no dashboard for this — run once after deploying):
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=https://<your-domain>/api/webhooks/telegram&secret_token=$TELEGRAM_WEBHOOK_SECRET"
TELEGRAM_WEBHOOK_SECRET=""
# Public @handle of the bot (no @), only used to render a clickable
# https://t.me/<handle> link in the workspace card. Purely cosmetic —
# leave unset and the card just shows text instructions instead.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# ── Payments (optional) ──────────────────────────────────────────────────────
# Razorpay Payment Links — used ONLY to collect INRP2P's own service fees
# (the Revenue ledger: introduction fees, success fees, retainers). This is
# completely separate from the underlying P2P trade funds between company
# and partner, which INRP2P never holds, transmits, or touches. Without
# these three set, the "Generate payment link" button is hidden and nothing
# breaks — the manual bank-transfer + status-dropdown flow keeps working.
#
# Key ID/Secret: Razorpay Dashboard → Settings → API Keys. Never paste these
# in chat, tickets, or commit them — treat like a bank password.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Webhook signing secret: Razorpay Dashboard → Settings → Webhooks → Add New
# Webhook → URL https://<your-domain>/api/webhooks/razorpay → enable the
# "payment_link.paid" event → Razorpay shows you this secret once, at
# creation time. Required for the webhook to accept and process events.
RAZORPAY_WEBHOOK_SECRET=""

# NOWPayments — used ONLY to collect INRP2P's own service fees when the
# payer settles in USDT (TRC20) instead of INR. Same boundary as Razorpay:
# never the underlying P2P trade funds. Without these two set, the
# "Generate USDT invoice" button is hidden and nothing breaks — the manual
# status-dropdown flow keeps working for crypto-fee records too.
#
# API key: NOWPayments Dashboard → Store Settings → generate an API key.
NOWPAYMENTS_API_KEY=""
# IPN secret: NOWPayments Dashboard → Payment Settings → Instant Payment
# Notifications → generate an IPN secret key, and set the IPN callback URL
# there to https://<your-domain>/api/webhooks/nowpayments. Also set
# "underpaid payments" to be flagged as partially_paid, not auto-finished —
# the webhook only ever trusts an exact "finished" status.
NOWPAYMENTS_IPN_SECRET=""

# ── AI features (optional) ───────────────────────────────────────────────────
# Powers the AI request briefing, plain-English match explanations, and deal
# room reply drafts. Uses a plain fetch() to the Anthropic Messages API — no
# extra package to install. Without this set, every AI button still renders
# but shows "AI is not configured" instead of a result; nothing else breaks.
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=""
# Optional override — check https://docs.claude.com/en/docs/about-claude/models
# for the current recommended model id if you want something other than the
# default baked into src/lib/ai.ts.
ANTHROPIC_MODEL=""

# ── Redis cache / rate limit (optional) ──────────────────────────────────────
# Upstash Redis REST API — plain fetch(), no SDK to install. Speeds up the
# heavier AI copilot aggregate queries (60s cache) and rate-limits the AI
# routes (20/min per admin, 12/min for the copilot) so a runaway loop or
# accidental abuse can't blow through your Anthropic credit balance. Without
# these set, everything still works — just without caching or a limit.
# Free tier at https://console.upstash.com — create a database, copy the
# REST URL and token from its dashboard.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
