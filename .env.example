# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, RDS, or self-hosted).
DATABASE_URL="postgresql://inrp2p:inrp2p@localhost:5432/inrp2p?schema=public"
# Direct (non-pooled) connection used by prisma migrate / db push.
# On Vercel+Neon this is set automatically; locally use the same value as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://inrp2p:inrp2p@localhost:5432/inrp2p?schema=public"

# ── Initial admin account (created by `npm run db:seed`) ────────────────────
# CHANGE BOTH VALUES BEFORE DEPLOYING. The seed only creates this one user —
# no fake companies, partners, requests, or deals are ever seeded.
ADMIN_EMAIL="admin@inrp2p.local"
ADMIN_PASSWORD="inrp2p-admin-2026"
ADMIN_NAME="Network Operator"

# ── Public site ─────────────────────────────────────────────────────────────
# Shown on the public contact section and confirmation pages.
NEXT_PUBLIC_CONTACT_EMAIL="network@inrp2p.example"
NEXT_PUBLIC_CONTACT_TELEGRAM="inrp2p_network"
