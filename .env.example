# Copy to .env for local development. Never commit real credentials.

# Database (required)
DATABASE_URL="postgresql://inrp2p:change-me@localhost:5432/inrp2p?schema=public"
DATABASE_URL_UNPOOLED="postgresql://inrp2p:change-me@localhost:5432/inrp2p?schema=public"

# Initial operator (required only when running npm run db:seed)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Network Operator"

# Public identity (required in production)
NEXT_PUBLIC_SITE_URL="https://inrp2p.com"
NEXT_PUBLIC_CONTACT_EMAIL="network@inrp2p.com"
NEXT_PUBLIC_CONTACT_TELEGRAM=""
NEXT_PUBLIC_CONTACT_TELEGRAM_CHANNEL=""
NEXT_PUBLIC_CONTACT_LINKEDIN="https://www.linkedin.com/company/inrp2p/"
NEXT_PUBLIC_APP_VERSION=""

# Email ownership and password recovery (required in production)
RESEND_API_KEY=""
EMAIL_FROM="INRP2P <security@inrp2p.com>"
# Development only. Never set a fixed OTP in production.
CUSTOMER_OTP_DEV_CODE=""

# Executable INR ↔ USDT pricing. Configure a real quote provider OR an
# operator-controlled execution rate. If neither is present, the UI truthfully
# reports pricing unavailable and does not fabricate an estimate.
EXECUTION_QUOTE_PROVIDER_URL=""
EXECUTION_QUOTE_PROVIDER_API_KEY=""
EXECUTION_RATE_INR_PER_USDT=""
INRP2P_FEE_BPS="100"
INRP2P_QUOTE_TTL_SECONDS="30"
INRP2P_EXECUTION_ETA_MINUTES=""
EXECUTION_MIN_INR="1000"
EXECUTION_MAX_INR="10000000"

# Financial data at rest (required for customer payment methods and references).
# FINANCIAL_DATA_ENCRYPTION_KEY must decode to exactly 32 random bytes (hex or
# base64). Keep the HMAC key separate in production and rotate via a managed
# secret store.
FINANCIAL_DATA_ENCRYPTION_KEY=""
FINANCIAL_DATA_HMAC_KEY=""

# Order controls
ORDER_PAYMENT_WINDOW_MINUTES="15"
ORDER_MAKER_CHECKER_REQUIRED="true"
ALLOW_UNVERIFIED_INR_DESTINATIONS="false"

# Real settlement adapter. Without this, provider release stays disabled;
# operators may only record a transfer after it occurred externally.
SETTLEMENT_PROVIDER_URL=""
SETTLEMENT_PROVIDER_API_KEY=""

# Signed transaction event adapters. Providers sign the exact raw request body
# with HMAC-SHA256 and send `x-inrp2p-signature: sha256=<hex>`.
PAYMENT_MATCHING_WEBHOOK_SECRET=""
SETTLEMENT_WEBHOOK_SECRET=""
SETTLEMENT_REQUIRED_CONFIRMATIONS=""

# Public-form abuse protection (required in production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Encrypted evidence vault (required to enable evidence uploads)
# Use a private S3 bucket. The IAM principal must be restricted to that bucket;
# the KMS key policy must allow encrypt/decrypt only for the application role.
EVIDENCE_S3_BUCKET=""
EVIDENCE_S3_REGION="ap-south-1"
EVIDENCE_S3_ENDPOINT=""
EVIDENCE_S3_ACCESS_KEY_ID=""
EVIDENCE_S3_SECRET_ACCESS_KEY=""
EVIDENCE_S3_KMS_KEY_ID=""

# Verification adapters (optional; absent providers become accountable manual review)
KYB_PROVIDER_URL=""
KYB_PROVIDER_API_KEY=""
AML_PROVIDER_URL=""
AML_PROVIDER_API_KEY=""
BANK_PROVIDER_URL=""
BANK_PROVIDER_API_KEY=""
WALLET_RISK_PROVIDER_URL=""
WALLET_RISK_PROVIDER_API_KEY=""

# Scheduled maintenance and operator alerts
CRON_SECRET=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALERT_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# WhatsApp Business notifications (optional)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANG="en"
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ALERT_PHONE=""

# Optional company-wallet override. Public TRON address only — never a seed phrase or private key.
USDT_TRC20_DEPOSIT_ADDRESS=""

# Platform service fees only; never client trade funds or partner reserves (optional)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# Optional internal operator assistance. Core routing never depends on AI.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Demo data is staging-only. The seed rejects weak or missing passwords.
DEMO_PASSWORD=""

# Preview-only database release guard. The branch and acknowledgement must be
# explicit; production uses prisma migrate deploy and runtime schema checks.
DATABASE_RELEASE_MODE=""
DATABASE_RELEASE_BRANCH=""
DATABASE_RELEASE_ACK="20260723000100_transaction_engine"
